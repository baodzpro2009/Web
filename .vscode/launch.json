{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Site On Localhost",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Server running at (https?://localhost:\\d+)",
        "uriFormat": "%s",
        "action": "debugWithEdge"
      }
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "Open Localhost Only",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
